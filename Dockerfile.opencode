FROM oven/bun:1

ENV HOME=/home/opencode
ENV XDG_CONFIG_HOME=/home/opencode/.config
ENV XDG_DATA_HOME=/home/opencode/.local/share
ENV PATH="/home/opencode/.bun/bin:${PATH}"
ENV BUN_INSTALL=/home/opencode/.bun
ENV BUN_INSTALL_BIN_DIR=/home/opencode/.bun/bin
ENV BUN_INSTALL_DIR=/home/opencode/.bun

RUN useradd -m -d /home/opencode -s /bin/bash opencode

WORKDIR /app

RUN bun add -g opencode-ai && bunx oh-my-opencode-slim@latest install --no-tui

COPY scripts/opencode-entrypoint.sh /usr/local/bin/opencode-entrypoint.sh
RUN chmod +x /usr/local/bin/opencode-entrypoint.sh && \
    mkdir -p /workspace /home/opencode/.config /home/opencode/.local/share && \
    chown -R opencode:opencode /workspace /home/opencode

USER opencode
WORKDIR /workspace

ENTRYPOINT ["/usr/local/bin/opencode-entrypoint.sh"]
