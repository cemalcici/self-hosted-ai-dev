# Exclude stale artifacts that would pollute the Dockerfile.single-container build context
**/node_modules
**/.git
**/dist
**/.next
**/.output
**/.cache
**/tmp
**/.temp
**/*.log
**/logs
**/.DS_Store
**/.env
**/.env.local
**/.env.*.local
**/coverage
**/.nyc_output
**/.pytest_cache
**/.mypy_cache
**/.turbo
**/.vercel
**/.svelte-kit
**/build
**/vendor
